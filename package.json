{
  "name": "hono-drizzle-postgresql-claude",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev tsx watch src/server.ts",
    "dev:debug": "cross-env NODE_ENV=dev tsx watch --inspect src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "cross-env NODE_ENV=prod node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.8.0",
    "@loglayer/transport-simple-pretty-terminal": "^3.3.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "hono-rate-limiter": "^0.5.3",
    "loglayer": "^9.4.0",
    "postgres": "^3.4.9",
    "uni-response": "^2.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "**/*.{ts,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "overrides": {
    "esbuild": "^0.25.4"
  }
}
